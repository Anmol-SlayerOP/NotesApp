# Test environment — used by Vitest for property-based tests that don't need a real DB.
# Integration tests that need a real DB should set DATABASE_URL in their own environment.
PORT=3001
NODE_ENV=test
DATABASE_URL=postgresql://test:test@localhost:5432/notes_test
JWT_SECRET=test-secret-key-for-unit-tests-only-not-production
JWT_EXPIRATION=1h
GEMINI_API_KEY=test-gemini-key
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000
DB_POOL_MIN=1
DB_POOL_MAX=2
